databases:
  - name: upskill-coach-db
    plan: basic-256mb
    region: virginia
    databaseName: upskill_coach
    user: upskill_coach_user

services:
  - type: web
    name: upskill-coach
    runtime: python
    plan: starter
    region: virginia
    # Build:
    #   1. Install Python deps
    #   2. Install Inter OTF into the project tree itself, then point
    #      fontconfig at it via the FONTCONFIG_PATH / XDG_DATA_HOME env
    #      vars (set further down). We tried $HOME/.fonts originally but
    #      Render's runtime $HOME differs from build $HOME, so the cache
    #      lived in the wrong place and Pango couldn't find Inter at
    #      runtime. Keeping fonts inside the project dir avoids that
    #      mismatch entirely.
    buildCommand: |
      pip install -r requirements.txt
      mkdir -p $HOME/.local/share/fonts
      cp fonts/inter/*.otf $HOME/.local/share/fonts/
      fc-cache -fv $HOME/.local/share/fonts || true
      # Sanity: confirm fontconfig sees Inter after the cache rebuild.
      # Failure here is non-fatal (we'd rather deploy and see the issue
      # than block the build) but the log line tells us at-a-glance
      # whether the install worked.
      fc-list | grep -i inter || echo "WARN: Inter not in fc-list after cache"
    startCommand: python coach.py
    healthCheckPath: /health
    envVars:
      - key: ANTHROPIC_API_KEY
        sync: false  # Set manually in Render dashboard
      - key: DATABASE_URL
        fromDatabase:
          name: upskill-coach-db
          property: connectionString
      # PORT is auto-set by Render — do not override
      - key: BIND_HOST
        value: "0.0.0.0"
      - key: PYTHON_VERSION
        value: "3.11.9"
      - key: PYTHONUNBUFFERED
        value: "1"
      # SMS tutor — all set manually in Render dashboard. The web
      # service needs them for /sms/inbound (Twilio signature) and
      # /sms/cron-tick (CRON_SECRET). The cron services below reuse
      # the same values via fromService.
      - key: TWILIO_ACCOUNT_SID
        sync: false
      - key: TWILIO_AUTH_TOKEN
        sync: false
      - key: TWILIO_FROM_NUMBER
        sync: false
      - key: TUTOR_USER_PHONE
        sync: false
      - key: TUTOR_USER_ID
        sync: false
      - key: CRON_SECRET
        sync: false

  # ─── SMS scheduled-slot triggers ───────────────────────────────────
  #
  # Render Cron Jobs are tiny containers that run a shell command on a
  # cron schedule. Each one curls /sms/cron-tick on the web service
  # above. The web service does the actual LLM call + Twilio send so
  # we keep all the heavy deps (anthropic, twilio, db pool) in one
  # place.
  #
  # Schedule is in UTC. The user is on PT, so:
  #   10am PT (morning)   = 17:00 UTC (PST) / 18:00 UTC (PDT)
  #    1pm PT (lunch)     = 20:00 UTC      / 21:00 UTC
  #    4pm PT (afternoon) = 23:00 UTC      / 00:00 UTC (next day)
  #    9pm PT (evening)   = 04:00 UTC next / 05:00 UTC
  # Cron times below are pinned to PST (winter). When PDT kicks in
  # (March), bump every hour by -1. Or vice-versa in November. Setting
  # a calendar reminder for the user is the MVP plan; auto-DST is v2.
  # Each cron job is just `curl -fsS -X POST ...` against the web
  # service. No app code in the cron container — keeps the deployable
  # surface tiny. Uses Render's prebuilt `curlimages/curl` Docker
  # image, which has nothing else in it.
  - type: cron
    name: sms-morning
    runtime: image
    image:
      url: docker.io/curlimages/curl:latest
    plan: starter
    region: virginia
    schedule: "0 17 * * *"
    startCommand: |
      curl -fsS -X POST \
        -H "X-Cron-Secret: $CRON_SECRET" \
        "https://upskill-coach.onrender.com/sms/cron-tick?slot=morning"
    envVars:
      - key: CRON_SECRET
        fromService:
          name: upskill-coach
          type: web
          envVarKey: CRON_SECRET

  - type: cron
    name: sms-lunch
    runtime: image
    image:
      url: docker.io/curlimages/curl:latest
    plan: starter
    region: virginia
    schedule: "0 20 * * *"
    startCommand: |
      curl -fsS -X POST \
        -H "X-Cron-Secret: $CRON_SECRET" \
        "https://upskill-coach.onrender.com/sms/cron-tick?slot=lunch"
    envVars:
      - key: CRON_SECRET
        fromService:
          name: upskill-coach
          type: web
          envVarKey: CRON_SECRET

  - type: cron
    name: sms-afternoon
    runtime: image
    image:
      url: docker.io/curlimages/curl:latest
    plan: starter
    region: virginia
    schedule: "0 23 * * *"
    startCommand: |
      curl -fsS -X POST \
        -H "X-Cron-Secret: $CRON_SECRET" \
        "https://upskill-coach.onrender.com/sms/cron-tick?slot=afternoon"
    envVars:
      - key: CRON_SECRET
        fromService:
          name: upskill-coach
          type: web
          envVarKey: CRON_SECRET

  - type: cron
    name: sms-evening
    runtime: image
    image:
      url: docker.io/curlimages/curl:latest
    plan: starter
    region: virginia
    schedule: "0 4 * * *"
    startCommand: |
      curl -fsS -X POST \
        -H "X-Cron-Secret: $CRON_SECRET" \
        "https://upskill-coach.onrender.com/sms/cron-tick?slot=evening"
    envVars:
      - key: CRON_SECRET
        fromService:
          name: upskill-coach
          type: web
          envVarKey: CRON_SECRET
